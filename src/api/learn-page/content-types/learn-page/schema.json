{
  "kind": "collectionType",
  "collectionName": "learn_pages",
  "info": {
    "singularName": "learn-page",
    "pluralName": "learn-pages",
    "displayName": "Learn Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "what-is"
      ]
    },
    "directAnswer": {
      "type": "blocks",
      "required": true
    },
    "helpsYouUnderstand": {
      "type": "blocks"
    },
    "railNote": {
      "type": "string"
    },
    "simpleExplanationHeading": {
      "type": "string"
    },
    "simpleExplanationBody": {
      "type": "blocks"
    },
    "ruleHeading": {
      "type": "string"
    },
    "ruleAndRealWorld": {
      "type": "component",
      "component": "learn.rule-real-world",
      "repeatable": false
    },
    "cairnulsConclusion": {
      "type": "blocks"
    },
    "cairnulHelpsHeading": {
      "type": "string"
    },
    "howCairnulHelps": {
      "type": "blocks"
    },
    "whatFoundersUsuallyMiss": {
      "type": "blocks"
    },
    "checklistHeading": {
      "type": "string"
    },
    "actionChecklist": {
      "type": "blocks"
    },
    "faq": {
      "type": "component",
      "component": "learn.faq-item",
      "repeatable": true
    },
    "relatedHeading": {
      "type": "string"
    },
    "relatedPages": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::learn-page.learn-page",
      "mappedBy": "learn_pages"
    },
    "learn_pages": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::learn-page.learn-page",
      "inversedBy": "relatedPages"
    },
    "relatedWaysAsked": {
      "type": "blocks"
    },
    "ctaHeading": {
      "type": "string"
    }
  }
}
